# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Spotify integration (https://developer.spotify.com/dashboard)
# IMPORTANT: Spotify no longer allows "localhost" as a redirect URI.
# Add http://127.0.0.1:3000/auth/spotify/callback to your app's Redirect URIs.
# For production, add your deployed URL (must be HTTPS).
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
APP_URL=http://127.0.0.1:3000
